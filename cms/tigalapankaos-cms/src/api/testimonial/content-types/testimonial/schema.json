{
  "kind": "collectionType",
  "collectionName": "testimonials",
  "info": {
    "singularName": "testimonial",
    "pluralName": "testimonials",
    "displayName": "Testimoni",
    "description": "Testimoni pelanggan yang tampil di website"
  },
  "options": { "draftAndPublish": true },
  "pluginOptions": {},
  "attributes": {
    "customerName": { "type": "string", "required": true },
    "roleOrCompany": { "type": "string", "description": "Contoh: Owner Distro ABC, Panitia Acara XYZ" },
    "photo": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5,
      "required": true
    },
    "content": { "type": "text", "required": true },
    "order": { "type": "integer", "default": 0 }
  }
}
