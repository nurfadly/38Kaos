HOST=0.0.0.0
PORT=1337

# Generate dengan: openssl rand -base64 32 (ulangi utk setiap key)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=tokensalt
ADMIN_JWT_SECRET=adminjwtsecret
TRANSFER_TOKEN_SALT=transfersalt
JWT_SECRET=jwtsecret
ENCRYPTION_KEY=encryptionkey

# Database (default sqlite untuk lokal; ganti ke postgres saat deploy production)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Contoh koneksi Postgres (Railway/Render akan mengisi otomatis via DATABASE_URL)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgres://user:pass@host:5432/dbname
# DATABASE_SSL=true

# Kunci rahasia untuk halaman Import Stok (public/import-stok.html).
# Isi dengan teks acak apa saja (mis. hasil `openssl rand -base64 24`), lalu masukkan
# nilai yang sama di kolom "Kunci Import" pada halaman import-stok.html saat dipakai.
INVENTORY_IMPORT_KEY=ganti-dengan-kunci-rahasia-anda
